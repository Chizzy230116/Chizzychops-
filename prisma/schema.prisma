generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  price       Int
  category    String
  subcat      String?
  description String   @default("")
  badge       String?
  badgeColor  String?  @map("badge_color")
  note        String?
  imgUrl      String   @default("") @map("img_url")
  img2Url     String?  @map("img2_url")
  sortOrder   Int      @default(99) @map("sort_order")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("menu_items")
}

model Order {
  id            String   @id @default(dbgenerated("('ORD-'::text || upper(\"substring\"((gen_random_uuid())::text, 1, 8)))"))
  customerName  String?  @map("customer_name")
  customerPhone String?  @map("customer_phone")
  items         Json
  total         Int
  status        String   @default("new")
  note          String?
  address       String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("orders")
}

model ContactSubmission {
  id        String   @id @default(dbgenerated("('MSG-'::text || upper(\"substring\"((gen_random_uuid())::text, 1, 8)))"))
  name      String
  phone     String
  email     String?
  message   String
  type      String   @default("contact")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("contact_submissions")
}

model ReviewSubmission {
  id         String   @id @default(dbgenerated("('REV-'::text || upper(\"substring\"((gen_random_uuid())::text, 1, 8)))"))
  name       String
  dish       String
  overall    Int
  taste      Int      @default(0)
  portion    Int      @default(0)
  delivery   Int      @default(0)
  packaging  Int      @default(0)
  value      Int      @default(0)
  recommend  Boolean  @default(true)
  reviewText String   @map("review_text")
  type       String   @default("review")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("review_submissions")
}

model CateringSubmission {
  id        String   @id @default(dbgenerated("('CAT-'::text || upper(\"substring\"((gen_random_uuid())::text, 1, 8)))"))
  name      String
  phone     String
  eventDate String   @map("event_date")
  guests    String
  eventType String   @default("") @map("event_type")
  notes     String   @default("")
  type      String   @default("catering")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("catering_submissions")
}
