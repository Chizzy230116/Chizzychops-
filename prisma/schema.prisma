// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MenuItem {
  id          String   @id
  name        String
  price       Float
  category    String
  subcat      String?
  description String   @default("")
  badge       String?
  badgeColor  String?  @map("badge_color")
  note        String?
  imgUrl      String   @default("") @map("img_url")
  img2Url     String?  @map("img2_url")
  sortOrder   Int      @default(99) @map("sort_order")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("menu_items")
}

model Order {
  id              String   @id @default(dbgenerated("('ORD-' || LPAD(nextval('orders_id_seq')::TEXT, 6, '0'))"))
  reference       String   @unique @default(dbgenerated("('REF-' || UPPER(SUBSTRING(gen_random_uuid()::TEXT, 1, 10)))"))
  customerName    String   @default("") @map("customer_name")
  customerEmail   String   @default("") @map("customer_email")
  customerPhone   String   @default("") @map("customer_phone")
  deliveryAddress String   @default("") @map("delivery_address")
  items           Json     @default("[]")
  subtotal        Int      @default(0)
  deliveryFee     Int      @default(0) @map("delivery_fee")
  total           Int      @default(0)
  status          String   @default("pending")
  paystackData    Json?    @map("paystack_data")
  whatsappSent    Boolean  @default(false) @map("whatsapp_sent")
  note            String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([reference])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

model ContactSubmission {
  id        String   @id @default(dbgenerated("('MSG-' || LPAD(nextval('contact_id_seq')::TEXT, 5, '0'))"))
  name      String
  phone     String
  email     String?
  message   String
  type      String   @default("contact")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("contact_submissions")
}

model ReviewSubmission {
  id         String   @id @default(dbgenerated("('REV-' || LPAD(nextval('review_id_seq')::TEXT, 5, '0'))"))
  name       String
  dish       String
  overall    Int
  taste      Int      @default(0)
  portion    Int      @default(0)
  delivery   Int      @default(0)
  packaging  Int      @default(0)
  value      Int      @default(0)
  recommend  Boolean  @default(true)
  reviewText String   @map("review_text")
  type       String   @default("review")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("review_submissions")
}

model CateringSubmission {
  id        String   @id @default(dbgenerated("('CAT-' || LPAD(nextval('catering_id_seq')::TEXT, 5, '0'))"))
  name      String
  phone     String
  eventDate String   @map("event_date")
  guests    String
  eventType String   @default("") @map("event_type")
  notes     String   @default("")
  type      String   @default("catering")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("catering_submissions")
}
